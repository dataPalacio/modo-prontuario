# ==============================================================================
# PRONTUÁRIO HOF - VARIÁVEIS DE AMBIENTE (Exemplo)
# Copie este arquivo para .env ou .env.local e preencha os valores reais.
# ==============================================================================

# 1. BANCO DE DADOS (PostgreSQL / Supabase)
# ------------------------------------------------------------------------------
# URL de conexão pelo Pooler (recomendado para Serverless, geralmente porta 6543)
# Ex: postgresql://[USER]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# URL de conexão direta (ex: porta 5432, útil para migrations pesadas no Prisma)
DIRECT_URL="postgresql://user:password@host:5432/postgres"


# 2. AUTENTICAÇÃO (NextAuth.js v5)
# ------------------------------------------------------------------------------
# Uma chave secreta para assinar os tokens JWT. Gere uma robusta usando:
# openssl rand -base64 32
AUTH_SECRET="seu_segredo_aqui"

# URL base da aplicação
# Local: http://localhost:3000
# Produção: https://seu-dominio.com.br
AUTH_URL="http://localhost:3000"

# Compatibilidade legsada (NextAuth v4 style)
NEXTAUTH_SECRET="seu_segredo_aqui"
NEXTAUTH_URL="http://localhost:3000"


# 3. STORAGE DE ARQUIVOS (Uploadthing)
# ------------------------------------------------------------------------------
# Obtenha em https://uploadthing.com/dashboard
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="vj9..."


# 4. EMAIL (Resend)
# ------------------------------------------------------------------------------
# Obtenha em https://resend.com/dashboard
RESEND_API_KEY="re_..."


# 5. IA AGENTS (Google Cloud / Vertex AI)
# ------------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID="seu-projeto-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="./credentials/service-account.json"

# IDs específicos dos agentes no Vertex AI Search and Conversation
VERTEX_AI_AGENT_ID_ANAMNESE="..."
VERTEX_AI_AGENT_ID_TCLE="..."
VERTEX_AI_AGENT_ID_REPORT="..."


# 6. CRIPTOGRAFIA (LGPD — CPF em repouso)
# ------------------------------------------------------------------------------
# Chave AES-256 para criptografar CPF dos pacientes.
# Gere com: openssl rand -hex 32
# ⚠️ NUNCA commitar o valor real — guarde em variáveis de ambiente do servidor.
AES_SECRET_KEY="64_caracteres_hex_aqui_ex_openssl_rand_hex_32"


# 7. CONFIGURAÇÕES ADICIONAIS
# ------------------------------------------------------------------------------
# NODE_ENV="development" # development, production, test
