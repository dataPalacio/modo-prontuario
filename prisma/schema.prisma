generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Clinica {
  id            String         @id @default(cuid())
  nome          String
  cnpj          String?        @unique
  endereco      String?
  telefone      String?
  email         String?
  logo          String?
  plano         Plano          @default(FREE)
  ativo         Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  agendamentos  Agendamento[]
  pacientes     Paciente[]
  profissionais Profissional[]
  prontuarios   Prontuario[]

  @@map("clinicas")
}

model Profissional {
  id             String       @id @default(cuid())
  clinicaId      String       @map("clinica_id")
  nome           String
  email          String       @unique
  senhaHash      String       @map("senha_hash")
  conselho       TipoConselho
  numeroConselho String       @map("numero_conselho")
  uf             String
  especialidade  String?
  assinaturaUrl  String?      @map("assinatura_url")
  role           Role         @default(PROFISSIONAL)
  ativo          Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  agendamentos   Agendamento[]
  auditLogs      AuditLog[]
  clinica        Clinica      @relation(fields: [clinicaId], references: [id])
  prontuarios    Prontuario[]

  @@map("profissionais")
}

model Paciente {
  id          String       @id @default(cuid())
  clinicaId   String       @map("clinica_id")
  nome        String
  cpf         String
  dataNasc    DateTime     @map("data_nasc")
  sexo        Sexo
  email       String?
  telefone    String
  whatsapp    String?
  endereco    Json?
  fotoUrl     String?      @map("foto_url")
  observacoes String?
  ativo       Boolean      @default(true)
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  cpfHash     String       @map("cpf_hash")
  agendamentos Agendamento[]
  clinica     Clinica      @relation(fields: [clinicaId], references: [id])
  prontuarios Prontuario[]
  tcles       Tcle[]

  @@unique([clinicaId, cpfHash])
  @@index([clinicaId])
  @@index([cpfHash])
  @@index([nome])
  @@map("pacientes")
}

model Prontuario {
  id              String           @id @default(cuid())
  clinicaId       String           @map("clinica_id")
  pacienteId      String           @map("paciente_id")
  profissionalId  String           @map("profissional_id")
  numero          String           @unique
  dataAtendimento DateTime         @map("data_atendimento")
  queixaPrincipal String           @map("queixa_principal")
  anamnese        Json?
  avaliacaoFacial Json?            @map("avaliacao_facial")
  status          StatusProntuario @default(ABERTO)
  assinadoPor     String?          @map("assinado_por")
  assinadoEm      DateTime?        @map("assinado_em")
  hashIntegridade String?          @map("hash_integridade")
  pdfUrl          String?          @map("pdf_url")
  deletedAt       DateTime?        @map("deleted_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  agendamentos    Agendamento[]
  evolucoes       Evolucao[]
  fotos           FotoClinica[]
  procedimentos   Procedimento[]
  clinica         Clinica          @relation(fields: [clinicaId], references: [id])
  paciente        Paciente         @relation(fields: [pacienteId], references: [id])
  profissional    Profissional     @relation(fields: [profissionalId], references: [id])
  tcle            Tcle?

  @@index([clinicaId])
  @@index([pacienteId])
  @@index([dataAtendimento(sort: Desc)])
  @@map("prontuarios")
}

model Agendamento {
  id             String            @id @default(cuid())
  clinicaId      String            @map("clinica_id")
  pacienteId     String            @map("paciente_id")
  profissionalId String            @map("profissional_id")
  prontuarioId   String?           @map("prontuario_id")
  dataHora       DateTime          @map("data_hora")
  duracaoMinutos Int               @default(60) @map("duracao_minutos")
  tipo           TipoAgendamento
  status         StatusAgendamento @default(AGENDADO)
  observacoes    String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  clinica        Clinica           @relation(fields: [clinicaId], references: [id])
  paciente       Paciente          @relation(fields: [pacienteId], references: [id])
  profissional   Profissional      @relation(fields: [profissionalId], references: [id])
  prontuario     Prontuario?       @relation(fields: [prontuarioId], references: [id])

  @@index([clinicaId, dataHora])
  @@index([profissionalId, dataHora])
  @@index([pacienteId, dataHora])
  @@index([status])
  @@map("agendamentos")
}

model Procedimento {
  id              String           @id @default(cuid())
  prontuarioId    String           @map("prontuario_id")
  tipo            TipoProcedimento
  regiaoAnatomica String           @map("regiao_anatomica")
  produto         String
  fabricante      String?
  lote            String
  validadeProduto DateTime?        @map("validade_produto")
  concentracao    String?
  volume          String?
  tecnica         String?
  observacoes     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  prontuario      Prontuario       @relation(fields: [prontuarioId], references: [id])

  @@index([prontuarioId])
  @@map("procedimentos")
}

model Evolucao {
  id                 String     @id @default(cuid())
  prontuarioId       String     @map("prontuario_id")
  data               DateTime
  descricao          String
  satisfacaoPaciente Int?       @map("satisfacao_paciente")
  retornoNecessario  Boolean    @default(false) @map("retorno_necessario")
  dataRetorno        DateTime?  @map("data_retorno")
  createdAt          DateTime   @default(now()) @map("created_at")
  prontuario         Prontuario @relation(fields: [prontuarioId], references: [id])

  @@index([prontuarioId])
  @@map("evolucoes")
}

model FotoClinica {
  id           String     @id @default(cuid())
  prontuarioId String     @map("prontuario_id")
  url          String
  tipo         TipoFoto
  angulo       String?
  descricao    String?
  createdAt    DateTime   @default(now()) @map("created_at")
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id])

  @@index([prontuarioId])
  @@map("fotos_clinicas")
}

model Tcle {
  id            String     @id @default(cuid())
  prontuarioId  String     @unique @map("prontuario_id")
  pacienteId    String     @map("paciente_id")
  conteudo      String
  assinaturaUrl String?    @map("assinatura_url")
  ipAssinatura  String?    @map("ip_assinatura")
  userAgent     String?    @map("user_agent")
  assinadoEm    DateTime?  @map("assinado_em")
  versao        String
  createdAt     DateTime   @default(now()) @map("created_at")
  paciente      Paciente   @relation(fields: [pacienteId], references: [id])
  prontuario    Prontuario @relation(fields: [prontuarioId], references: [id])

  @@map("tcles")
}

model AuditLog {
  id           String       @id @default(cuid())
  clinicaId    String       @map("clinica_id")
  userId       String       @map("user_id")
  acao         String
  entidade     String
  entidadeId   String       @map("entidade_id")
  ip           String
  userAgent    String?      @map("user_agent")
  dados        Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  clinica      Clinica      @relation(fields: [clinicaId], references: [id])
  profissional Profissional @relation(fields: [userId], references: [id])

  @@index([clinicaId])
  @@index([entidade, entidadeId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum TipoConselho {
  CFM
  CFO
  CFBM
  CFF
}

enum Role {
  ADMIN
  PROFISSIONAL
  RECEPCIONISTA
}

enum Plano {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum Sexo {
  MASCULINO
  FEMININO
  OUTRO
  NAO_INFORMADO
}

enum StatusProntuario {
  ABERTO
  EM_ANDAMENTO
  ASSINADO
  ARQUIVADO
}

enum TipoProcedimento {
  TOXINA_BOTULINICA
  PREENCHIMENTO_ACIDO_HIALURONICO
  BIOESTIMULADOR_COLAGENO
  FIOS_PDO
  RINOMODELACAO
  BICHECTOMIA
  LIPOFILLING_FACIAL
  PEELING_QUIMICO
  SKINBOOSTER
  MICROAGULHAMENTO
  OUTRO
}

enum TipoFoto {
  ANTES
  DEPOIS
  INTRAOPERATORIO
  RETORNO
}

enum TipoAgendamento {
  CONSULTA
  RETORNO
  PROCEDIMENTO
  AVALIACAO
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  REALIZADO
  CANCELADO
  FALTOU
}
